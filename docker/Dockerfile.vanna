FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "pydantic-ai[openai]" \
    "vanna[chromadb,openai]" \
    psycopg2-binary \
    pandas \
    python-dotenv \
    flask \
    docker \
    pyyaml \
    dbt-postgres

COPY vanna/ .
COPY dbt/ /dbt-baked/
# Put profiles.yml in dbt's standard home so it's always found regardless of --profiles-dir
RUN mkdir -p /root/.dbt && cp /dbt-baked/profiles.yml /root/.dbt/profiles.yml

EXPOSE 8084

# If the /dbt bind mount is empty (no dbt_project.yml), seed it from the baked copy.
# This handles Coolify deployments where ./dbt resolves to a fresh empty host directory.
CMD ["sh", "-c", "[ -d /dbt/profiles.yml ] && rm -rf /dbt/profiles.yml; [ -f /dbt/dbt_project.yml ] || cp -a /dbt-baked/. /dbt/; [ -f /dbt/profiles.yml ] || cp /dbt-baked/profiles.yml /dbt/profiles.yml; rm -rf /data/vanna-chroma/* && python train.py && python app.py"]
