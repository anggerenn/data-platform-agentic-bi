FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "pydantic-ai[openai]" \
    "vanna[chromadb,openai]" \
    psycopg2-binary \
    pandas \
    python-dotenv \
    flask \
    docker \
    pyyaml \
    dbt-postgres

COPY vanna/ .

EXPOSE 8084

CMD ["sh", "-c", "rm -rf /data/vanna-chroma/* && python train.py && python app.py"]
