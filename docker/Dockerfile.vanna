FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "pydantic-ai[openai]" \
    "vanna[chromadb,openai]" \
    psycopg2-binary \
    pandas \
    python-dotenv \
    flask \
    docker \
    pyyaml \
    dbt-postgres

COPY vanna/ .
COPY dbt/ /dbt-baked/

EXPOSE 8084

# If the /dbt bind mount is empty (no dbt_project.yml), seed it from the baked copy.
# This handles Coolify deployments where ./dbt resolves to a fresh empty host directory.
CMD ["sh", "-c", "[ -f /dbt/dbt_project.yml ] || cp -rn /dbt-baked/. /dbt/ ; rm -rf /data/vanna-chroma/* && python train.py && python app.py"]
