# .env.example — copy to .env and fill in secrets
# Vars already defaulted in docker-compose.yml are omitted here.

# ── Database passwords ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
ANALYTICS_DB_PASSWORD=changeme
ANALYTICS_DB_READONLY_PASSWORD=changeme_readonly

# ── Lightdash ─────────────────────────────────────────────────────────────────
LIGHTDASH_SECRET=changeme
LIGHTDASH_EMAIL=admin@example.com
LIGHTDASH_PASSWORD=your_secure_password
# Leave empty on first boot — lightdash-deploy will print the token to logs.
# Set it here after first boot, then redeploy.
LIGHTDASH_API_KEY=
# Public URL shown in the chat widget (browser-facing)
# Local: http://localhost:8080  |  VPS: https://lightdash.yourdomain.com
LIGHTDASH_PUBLIC_URL=http://localhost:8080

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_PASSWORD=changeme

# ── AI ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Volume paths (Coolify/VPS only) ──────────────────────────────────────────
# Leave unset locally — named Docker volumes are used as fallback.
# On Coolify: set all of these to persist data across redeployments.
PREFECT_DB_DATA=/data/prefect-db
ANALYTICS_DB_DATA=/data/analytics-db
LIGHTDASH_DB_DATA=/data/lightdash-db
MINIO_DATA=/data/minio
PIPELINES_DATA=/data/pipelines
VANNA_DATA=/data/vanna
CHROMA_CACHE=/data/chroma-cache
